{
  "name": "doccupine",
  "version": "0.0.33",
  "description": "Generate beautiful, ready-to-use documentation with just one CLI command – fast, simple, and open source.",
  "main": "dist/index.js",
  "bin": {
    "doccupine": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "doccupine",
    "documentation",
    "docs",
    "mdx",
    "ai",
    "llm",
    "nextjs",
    "cli",
    "generator",
    "file-watcher",
    "static-site-generator"
  ],
  "homepage": "https://doccupine.com",
  "repository": "https://github.com/thethemefoundry/doccupine-cli",
  "author": "Luan Gjokaj",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.3",
    "gray-matter": "^4.0.3",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/chokidar": "^2.1.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.1",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/**/*"
  ]
}
