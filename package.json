{
  "name": "doccupine",
  "version": "0.0.1",
  "description": "CLI tool to watch MDX files and generate Next.js beautiful documentation pages automatically",
  "main": "dist/index.js",
  "bin": {
    "doccupine-beta": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "doccupine",
    "documentation",
    "mdx",
    "nextjs",
    "cli",
    "file-watcher",
    "static-site-generator"
  ],
  "author": "Luan Gjokaj",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.5",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist/**/*"
  ]
}
