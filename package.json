{
  "name": "doccupine",
  "version": "0.0.89",
  "description": "Free and open-source documentation platform. Write MDX, get a production-ready site with AI chat, built-in components, and an MCP server - in one command.",
  "main": "dist/index.js",
  "bin": {
    "doccupine": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "tsc",
    "test": "vitest run",
    "format": "prettier --write ."
  },
  "keywords": [
    "doccupine",
    "documentation",
    "docs",
    "mdx",
    "ai",
    "llm",
    "mcp",
    "nextjs",
    "cli",
    "generator",
    "file-watcher",
    "static-site-generator"
  ],
  "homepage": "https://doccupine.com",
  "repository": "https://github.com/doccupine/cli",
  "author": "Luan Gjokaj",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.5",
    "gray-matter": "^4.0.3",
    "next": "^16.2.6",
    "prompts": "^2.4.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.2",
    "@types/prompts": "^2.4.9",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist/**/*"
  ]
}
